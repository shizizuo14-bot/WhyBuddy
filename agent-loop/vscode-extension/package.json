{
  "name": "agent-loop-dashboard",
  "displayName": "AgentLoop Dashboard",
  "description": "Visual progress for AgentLoop task queue, gates, and Codex/Grok review runs.",
  "version": "0.1.34",
  "publisher": "cube-pets-office",
  "license": "MIT",
  "icon": "media/sliderule-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:agent-loop/package.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-loop",
          "title": "AgentLoop",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agent-loop": [
        {
          "id": "agentLoop.queue",
          "name": "任务队列"
        },
        {
          "id": "agentLoop.currentRun",
          "name": "当前运行"
        },
        {
          "id": "agentLoop.runs",
          "name": "历史运行"
        }
      ]
    },
    "commands": [
      {
        "command": "agentLoop.runQueue",
        "title": "AgentLoop: 运行任务队列",
        "icon": "$(play)"
      },
      {
        "command": "agentLoop.stopRun",
        "title": "AgentLoop: 停止当前运行",
        "icon": "$(debug-stop)"
      },
      {
        "command": "agentLoop.openDashboard",
        "title": "AgentLoop: 打开可视化面板",
        "icon": "$(dashboard)"
      },
      {
        "command": "agentLoop.openFinalReport",
        "title": "AgentLoop: 打开最终报告",
        "icon": "$(book)"
      },
      {
        "command": "agentLoop.openStateJson",
        "title": "AgentLoop: 打开 state.json",
        "icon": "$(json)"
      },
      {
        "command": "agentLoop.refresh",
        "title": "刷新",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentLoop.runQueue",
          "when": "view == agentLoop.queue && !agentLoop.queueRunning",
          "group": "navigation@1"
        },
        {
          "command": "agentLoop.stopRun",
          "when": "(view == agentLoop.queue || view == agentLoop.currentRun) && agentLoop.queueRunning",
          "group": "navigation@1"
        },
        {
          "command": "agentLoop.openDashboard",
          "when": "view == agentLoop.currentRun",
          "group": "navigation@2"
        },
        {
          "command": "agentLoop.refresh",
          "when": "view == agentLoop.currentRun || view == agentLoop.queue || view == agentLoop.runs",
          "group": "navigation@9"
        }
      ]
    },
    "configuration": {
      "title": "AgentLoop",
      "properties": {
        "agentLoop.pollIntervalMs": {
          "type": "number",
          "default": 1500,
          "minimum": 500,
          "description": "轮询 .agent-loop/latest/state.json 的间隔（毫秒）"
        },
        "agentLoop.queuePath": {
          "type": "string",
          "default": "agent-loop/scripts/migration-queue.json",
          "description": "任务队列 JSON 路径（相对仓库根目录）"
        },
        "agentLoop.openDashboardOnRun": {
          "type": "boolean",
          "default": true,
          "description": "启动 run-queue 时自动打开可视化面板"
        },
        "agentLoop.fixAgent": {
          "type": "string",
          "enum": ["grok", "codex"],
          "default": "grok",
          "description": "默认修复 Worker (CLI)"
        },
        "agentLoop.reviewAgent": {
          "type": "string",
          "enum": ["grok", "codex", "none"],
          "default": "codex",
          "description": "默认 Review Worker (CLI)"
        },
        "agentLoop.workerMaxTurns": {
          "type": "number",
          "default": 128,
          "description": "最大执行轮次"
        },
        "agentLoop.workerMaxRetries": {
          "type": "number",
          "default": 2,
          "description": "最大重试次数"
        },
        "agentLoop.worktreeScope": {
          "type": "string",
          "enum": ["queue", "task"],
          "default": "queue",
          "description": "工作树模式"
        },
        "agentLoop.baseUrl": {
          "type": "string",
          "default": "",
          "description": "LLM 代理地址 / Base URL"
        },
        "agentLoop.injectKeysToWorker": {
          "type": "boolean",
          "default": true,
          "description": "是否将 LLM Keys 注入 Worker 环境"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "dev:dashboard": "vite --host 127.0.0.1 --port 5173 --config vite.dashboard.dev.config.ts",
    "build:dashboard": "vite build --config vite.dashboard.config.ts",
    "watch": "tsc -watch -p .",
    "test": "node --test ../test/vscode-extension.test.js",
    "package": "npm run compile && npm run build:dashboard && npx @vscode/vsce package --no-dependencies --no-rewrite-relative-links"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@antv/g6": "^5.1.1",
    "antd": "^5.29.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.4.0",
    "vite": "^7.1.7"
  }
}
